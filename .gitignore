# Environment variables (contain secrets)
.env
*.env

# Generated status files (runtime state)
camera_status.json
fatigue_status.json
whiteboard_status.json

# History logs (time-series data)
whiteboard_history.jsonl

# Generated screenshots (runtime artifacts)
latest_frame.jpg
latest_fatigue_frame.jpg
latest_whiteboard_frame.jpg

# Log files
*.log

# Python cache
__pycache__/
*.pyc

# OS files
.DS_Store

# Downloaded model cache (large model files)
# Note: depthai_models/*.yaml are kept in git (tiny config files)
.depthai/
*.blob
*.bin

# PC testing artifacts (local Windows/Mac testing)
pc-testing/*.jpg
pc-testing/*.json
pc-testing/*.log
pc-testing/models/
pc-testing/*.pt
pc-testing/.cache/
pc-testing/.depthai_cached_models/

# Webcam testing artifacts
webcam/*.pt
webcam/__pycache__/
webcam/.models/

# Claude Code local settings (user-specific)
.claude/settings.local.json

# Task management (keep lessons.md, gitignore personal todos)
tasks/todo.md
tasks/todo-*.md